---
import impacto from "../../content/data/impacto.json";
---

<section id="impacto" class="impact-section">
  <div class="container">
    <div class="impact-head reveal">
      <p class="impact-eyebrow">Impacto medible</p>
      <h2 class="impact-title">Resultados que pueden mostrarse.</h2>
      <p class="impact-text">
        Sembralas convierte el trabajo ambiental en evidencia concreta: jornadas,
        participación y restauración documentada.
      </p>
    </div>

    <div class="impact-grid">
      {impacto.map((item) => (
        <article class="impact-card reveal">
<p class="impact-value">
  <span class="impact-number">{item.value.toLocaleString("es-CO")}</span><span class="impact-suffix">{item.suffix}</span>
</p>
          <p class="impact-label">{item.label}</p>
        </article>
      ))}
    </div>
  </div>
</section>